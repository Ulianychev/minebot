{
  "name": "farmbot",
  "version": "1.0.0",
  "description": "AFK mineflayer bot for a Minecraft lobby flow",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:afk3": "node -r dotenv/config index.js dotenv_config_path=.env.afk3",
    "start:premium": "node -r dotenv/config premium-afk.js dotenv_config_path=.env.premium",
    "start:gold": "node -r dotenv/config gold-bot.js dotenv_config_path=.env.gold",
    "start:mayday": "node -r dotenv/config mayday-bot.js dotenv_config_path=.env.mayday",
    "check": "node --check index.js",
    "check:gold": "node --check gold-bot.js",
    "check:premium": "node --check premium-afk.js",
    "check:mayday": "node --check mayday-bot.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.1",
    "mineflayer": "^4.37.0",
    "pngjs": "^7.0.0",
    "vec3": "^0.2.0"
  }
}
